{
  "//WARNING": "TEMPORARY PRE-LAUNCH RULES — presence/sos/positions are OPEN (no auth) so the realtime layer works on mobile browsers where Firebase anonymous auth (IndexedDB) is blocked by iOS Safari ITP / storage partitioning. BEFORE PUBLIC LAUNCH: re-require auth and add Firebase App Check. Tracking: re-tighten presence/sos/positions to 'auth != null' once mobile auth is reliable. Other nodes (checkin/geo/tokens/alarms/invites/pairs) remain auth-gated.",

  "rules": {
    ".read": false,
    ".write": false,

    "presence": {
      ".read": true,
      "$uid": {
        ".write": true,
        ".validate": "newData.hasChildren(['lat','lng','ts'])"
      }
    },

    "sos": {
      ".read": true,
      "$id": {
        ".write": true,
        ".validate": "newData.hasChildren(['uid','lat','lng','ts'])"
      }
    },

    "positions": {
      ".read": true,
      "$uid": {
        ".write": true
      }
    },

    "tombstones": {
      ".read": true,
      "$uid": {
        ".write": true,
        ".validate": "newData.hasChild('deleted')"
      }
    },

    "checkin": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "geo": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "tokens": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "alarms": {
      ".read": false,
      "$id": {
        ".write": "auth != null && newData.child('fromUid').val() === auth.uid",
        ".validate": "newData.hasChildren(['toUid','fromUid'])"
      }
    },

    "invites": {
      "$token": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "pairs": {
      "$uid": {
        ".read": "auth != null",
        "$other": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    }
  }
}
