{
  "rules": {
    ".read": false,
    ".write": false,

    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['lat','lng','ts'])"
      }
    },

    "sos": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid)",
        ".validate": "newData.hasChildren(['uid','lat','lng','ts'])"
      }
    },

    "positions": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "checkin": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "geo": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "tokens": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "alarms": {
      ".read": false,
      "$id": {
        ".write": "auth != null && newData.child('fromUid').val() === auth.uid",
        ".validate": "newData.hasChildren(['toUid','fromUid'])"
      }
    },

    "invites": {
      "$token": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "pairs": {
      "$uid": {
        ".read": "auth != null",
        "$other": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    }
  }
}
