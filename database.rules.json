{
  "rules": {
    "registry": {
      ".read": false,
      ".write": "auth != null"
    },
    "pairs": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "invites": {
      "$token": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['fromUid','ts'])"
      }
    },
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "ping": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null"
      }
    },
    "sos": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "aeds": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && (!data.exists() || data.child(\"by\").val() == auth.uid)",
        ".validate": "newData.hasChildren([\"lat\",\"lng\",\"by\",\"ts\"])"
      }
    }
  }
}